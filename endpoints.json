          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["slots", "available"]
        },
        "header": []
      }
    },
    {
      "name": "Vehicle Entry",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8080/parking/entry",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["parking", "entry"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ticketId\": \"T1\",\n  \"vehicle\": {\n    \"vehicleNumber\": \"KA01AB1234\",\n    \"vehicleType\": \"CAR\"\n  }\n}"
        }
      }
    },
    {
      "name": "Vehicle Exit",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8080/parking/exit/T1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["parking", "exit", "T1"]
        },
        "header": []
      }
    },
    {
      "name": "Create Payment",
      "request": {
