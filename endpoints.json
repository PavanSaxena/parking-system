            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"paymentId\": \"P1\",\n  \"amount\": 50,\n  \"paymentStatus\": \"COMPLETED\"\n}"
        }
      }
    },
    {
      "name": "Get Tickets Report",
      "request": {
        "method": "GET",
