{
  "info": {
    "name": "Parking System API",
    "_postman_id": "parking-system-api-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Add Parking Slot",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8080/admin/slots",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["admin", "slots"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"slotId\": \"S1\",\n  \"slotType\": \"CAR\",\n  \"status\": \"AVAILABLE\"\n}"
        }
      }
    },
    {
      "name": "Get All Slots",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/slots",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["slots"]
        },
        "header": []
      }
    },
    {
      "name": "Get Available Slots",
      "request": {
        "method": "GET",
        "url": {
